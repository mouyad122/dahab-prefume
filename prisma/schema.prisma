datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================
// ORIGINAL PRODUCT MODELS
// ============================================================

model Product {
  id                   String   @id @default(uuid())
  sku                  String   @unique
  slug                 String   @unique
  name_ar              String
  name_en              String?
  inspired_by          String?
  main_category        String   @default("general")
  gender               String   @default("unisex")
  season               String   @default("all")
  fragrance_family_raw String   @default("")
  short_description_ar String   @default("")
  short_description_en String?
  long_description_ar  String?
  long_description_en  String?
  keywords_ar          String   @default("")
  image_filename       String   @default("")
  needs_image          Boolean  @default(true)
  visible_on_website   Boolean  @default(true)
  featured_on_frontend Boolean  @default(false)
  low_stock_threshold  Int      @default(300)
  notes_top            String?
  notes_heart          String?
  notes_base           String?
  notes                String?
  research_confidence  String   @default("medium")
  needs_review         Boolean  @default(false)
  source_excel_row     Int?     @unique
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  // --- NEW V3 FIELDS ---
  category_slug        String?
  season_slug          String?
  has_image            Boolean @default(false)
  image_url            String?
  ready_for_storefront Boolean @default(false)
  visible              Boolean @default(false)
  featured             Boolean @default(false)
  fragrance_family     String  @default("")
  keywords             String  @default("")
  short_description    String  @default("")
  image_name           String?
  inventory_mode       String  @default("BULK_LIQUID") // FINISHED_PRODUCT, FORMULA_BASED, or BULK_LIQUID
  bulk_stock_ml        Float   @default(1000)

  categoryId          String?
  category            Category?           @relation(fields: [categoryId], references: [id])
  variants            ProductVariant[]
  accords             ProductAccord[]
  family_tags         ProductFamilyTag[]
  discounts           Discount[]
  sale_items          SaleItem[]
  inventory_movements InventoryMovement[]
  formulas            ProductFormula[]

  @@index([slug])
  @@index([sku])
  @@index([visible_on_website])
  @@index([featured_on_frontend])
  @@index([gender])
  @@index([season])
  @@index([main_category])
  @@index([needs_review])
  @@index([categoryId])
}

model ProductVariant {
  id        String @id @default(uuid())
  productId String
  volume    String // "50", "100", "200", "60", "1000", etc.
  price     Int // in fils
  stock     Int    @default(0)

  product  Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  formulas ProductFormula[]

  @@unique([productId, volume])
}

model ProductAccord {
  id        String           @id @default(uuid())
  productId String
  accordId  String?
  position  Int
  name_ar   String
  strength  Int
  product   Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  accord    FragranceAccord? @relation(fields: [accordId], references: [id])

  @@unique([productId, position])
  @@index([name_ar])
}

model ProductFamilyTag {
  id        String  @id @default(uuid())
  productId String
  tag_ar    String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, tag_ar])
  @@index([tag_ar])
}

model GlobalPricingSettings {
  id               String   @id @default(uuid())
  price_50ml_fils  Int
  price_100ml_fils Int
  price_200ml_fils Int
  currency         String   @default("JOD")
  active           Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}

// ============================================================
// CATEGORIES
// ============================================================

model Category {
  id             String   @id @default(uuid())
  slug           String   @unique
  name_ar        String
  name_en        String
  description_ar String?
  description_en String?
  image          String?
  display_order  Int      @default(0)
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  products Product[]

  @@index([slug])
  @@index([is_active])
}

// ============================================================
// DISCOUNTS
// ============================================================

model Discount {
  id               String    @id @default(uuid())
  productId        String
  discount_type    String    @default("percentage")
  discount_value   Float
  original_price   Int
  discounted_price Int
  starts_at        DateTime?
  ends_at          DateTime?
  is_active        Boolean   @default(true)
  label_ar         String?
  label_en         String?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([is_active])
}

// ============================================================
// EMPLOYEES & PERMISSIONS
// ============================================================

model Employee {
  id            String   @id @default(uuid())
  username      String   @unique
  password_hash String
  display_name  String
  role          String   @default("employee")
  is_active     Boolean  @default(true)
  pin_hash      String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  permissions    EmployeePermission?
  sales          Sale[]
  login_attempts LoginAttempt[]

  @@index([username])
  @@index([is_active])
}

model EmployeePermission {
  id                              String   @id @default(uuid())
  employeeId                      String   @unique
  can_access_counter              Boolean  @default(true)
  can_view_invoices               Boolean  @default(true)
  can_print_reports               Boolean  @default(true)
  can_add_notes                   Boolean  @default(true)
  can_view_inventory              Boolean  @default(false)
  can_manage_products             Boolean  @default(false)
  can_manage_employees            Boolean  @default(false)
  can_view_accounting             Boolean  @default(false)
  can_view_settings               Boolean  @default(false)
  can_manage_raw_materials        Boolean  @default(false)
  can_adjust_raw_material_stock   Boolean  @default(false)
  can_view_raw_material_movements Boolean  @default(false)
  can_manage_product_formulas     Boolean  @default(false)
  can_view_consumption_reports    Boolean  @default(false)
  created_at                      DateTime @default(now())
  updated_at                      DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// ============================================================
// SALES (POS)
// ============================================================

model Sale {
  id                   String   @id @default(uuid())
  invoice_number       String   @unique
  employeeId           String?
  seller_user_id       String?
  seller_name_snapshot String?
  seller_role_snapshot String?
  sale_source          String   @default("STAFF_POS")
  subtotal             Int
  discount_total       Int      @default(0)
  total                Int
  amount_received      Int      @default(0)
  change_amount        Int      @default(0)
  payment_method       String   @default("cash")
  status               String   @default("completed")
  notes                String?
  employee_note        String?
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  employee Employee?  @relation(fields: [employeeId], references: [id])
  items    SaleItem[]

  @@index([employeeId])
  @@index([seller_user_id])
  @@index([sale_source])
  @@index([status])
  @@index([created_at])
  @@index([invoice_number])
}

model SaleItem {
  id              String  @id @default(uuid())
  saleId          String
  productId       String?
  product_name_ar String
  product_name_en String?
  product_sku     String
  quantity        Int
  unit_price      Int
  total_price     Int
  volume          String?

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([saleId])
  @@index([productId])
}

// ============================================================
// INVENTORY MOVEMENTS
// ============================================================

model InventoryMovement {
  id              String   @id @default(uuid())
  productId       String
  variantId       String?
  old_quantity    Int
  new_quantity    Int
  quantity_change Int
  reason          String
  adjusted_by     String
  created_at      DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([created_at])
}

// ============================================================
// SITE SETTINGS
// ============================================================

model SiteSettings {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  value_type String   @default("string")
  category   String   @default("general")
  label_ar   String?
  label_en   String?
  updated_at DateTime @updatedAt

  @@index([key])
  @@index([category])
}

// ============================================================
// SECURITY
// ============================================================

model LoginAttempt {
  id         String   @id @default(uuid())
  ip_address String
  username   String?
  user_type  String   @default("admin")
  success    Boolean  @default(false)
  employeeId String?
  created_at DateTime @default(now())

  employee Employee? @relation(fields: [employeeId], references: [id])

  @@index([ip_address])
  @@index([created_at])
  @@index([user_type])
}

model SecurityEvent {
  id         String    @id @default(uuid())
  ip_address String
  event_type String
  details    String?
  is_blocked Boolean   @default(false)
  expires_at DateTime?
  created_at DateTime  @default(now())

  @@index([ip_address])
  @@index([is_blocked])
  @@index([created_at])
}

model BlockedIP {
  id         String    @id @default(uuid())
  ip_address String    @unique
  reason     String?
  blocked_by String    @default("system")
  expires_at DateTime?
  created_at DateTime  @default(now())

  @@index([ip_address])
}

// ============================================================
// CONTACT INQUIRIES
// ============================================================

model ContactInquiry {
  id         String   @id @default(uuid())
  name       String
  phone      String
  type       String   @default("استفسار عام")
  message    String
  status     String   @default("new")
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([created_at])
}

// ============================================================
// NEW: FRAGRANCE ACCORDS
// ============================================================

model FragranceAccord {
  id         String   @id @default(uuid())
  name_ar    String
  name_en    String?
  slug       String   @unique
  color      String   @default("#000000")
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product_accords ProductAccord[]
}

// ============================================================
// NEW: RAW MATERIALS
// ============================================================

model RawMaterial {
  id                  String   @id @default(uuid())
  name_ar             String
  name_en             String?
  sku                 String?  @unique
  type                String // perfume_oil, alcohol, fixative, bottle, cap, etc.
  unit                String // ml, piece, gram
  current_quantity    Float    @default(0)
  low_stock_threshold Int      @default(0)
  cost_per_unit       Float    @default(0)
  is_active           Boolean  @default(true)
  notes               String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  movements     RawMaterialMovement[]
  formula_items ProductFormulaItem[]
}

model RawMaterialMovement {
  id              String   @id @default(uuid())
  raw_material_id String
  movement_type   String // STOCK_IN, STOCK_OUT, SALE_CONSUMPTION, MANUAL_ADJUSTMENT, etc.
  quantity_change Float
  quantity_before Float
  quantity_after  Float
  unit            String
  reason          String?
  reference_type  String?
  reference_id    String?
  created_by      String
  created_at      DateTime @default(now())

  raw_material RawMaterial @relation(fields: [raw_material_id], references: [id])

  @@index([raw_material_id])
  @@index([movement_type])
  @@index([created_at])
}

// ============================================================
// NEW: PRODUCT FORMULAS
// ============================================================

model ProductFormula {
  id              String   @id @default(uuid())
  productId       String
  variantId       String?
  name            String?
  total_volume_ml Float?
  is_active       Boolean  @default(true)
  version         Int      @default(1)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  product Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant?      @relation(fields: [variantId], references: [id], onDelete: Cascade)
  items   ProductFormulaItem[]

  @@index([productId])
  @@index([variantId])
}

model ProductFormulaItem {
  id              String @id @default(uuid())
  formula_id      String
  raw_material_id String
  quantity        Float
  unit            String
  quantity_ml     Float?
  sort_order      Int    @default(0)

  formula      ProductFormula @relation(fields: [formula_id], references: [id], onDelete: Cascade)
  raw_material RawMaterial    @relation(fields: [raw_material_id], references: [id])

  @@index([formula_id])
  @@index([raw_material_id])
}
