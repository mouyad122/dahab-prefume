# Database URLs - server only, never expose with NEXT_PUBLIC
DATABASE_URL="file:./dev.db"
DIRECT_URL=""

# Application Environment
NODE_ENV=production

# Admin & Employee JWT Secrets - minimum 32 characters
ADMIN_JWT_SECRET="replace-with-a-random-admin-secret-at-least-32-chars"
EMPLOYEE_JWT_SECRET="replace-with-a-random-employee-secret-at-least-32-chars"

# Super Admin Credentials - server only, never prefix with NEXT_PUBLIC
ADMIN_USERNAME=""
ADMIN_PASSWORD=""

# Supabase publishable values can be public only when RLS/storage policies are safe
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Supabase secret key - server only
SUPABASE_SECRET_KEY=""

# LangCache - server only
LANGCACHE_SERVER_URL=""
LANGCACHE_CACHE_ID=""
LANGCACHE_API_KEY=""
