# Database URL
# Local development: SQLite (file:./dev.db)
# Production: PostgreSQL (Neon, Supabase, Vercel Postgres, etc.)
DATABASE_URL="file:./dev.db"

# Application Environment
NODE_ENV=production

# Admin & Employee JWT Secrets
ADMIN_JWT_SECRET="dahab-admin-super-secret-key-change-in-production"
EMPLOYEE_JWT_SECRET="dahab-employee-super-secret-key-change-in-production"

# Default Super Admin Credentials
NEXT_PUBLIC_ADMIN_USERNAME="admin"
NEXT_PUBLIC_ADMIN_PASSWORD="dahab-change-me"
